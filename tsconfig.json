{
  "include": ["src/**/*", "tests/**/*", "supabase/**/*", "migrate.ts", "env/**/*"],
  "exclude": ["node_modules"],
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "paths": {
      "@env/*" : ["./env/*"]
    },
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "verbatimModuleSyntax": true,
    "types": [
      "node",
      "vite/client"
    ]
  }
}
